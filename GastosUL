         onclick="document.getElementById('fileInputVar').click()">
      <div class="upload-icon">📂</div>
      <div class="upload-title">Arrastra o haz clic para cargar archivos Excel</div>
      <div class="upload-sub">Gastos variables de tarjetas de crédito (.xlsx, .xls, .csv)</div>
      <input type="file" id="fileInputVar" class="upload-file-input" accept=".xlsx,.xls,.csv" multiple onchange="handleFileUpload(event)">
      <div class="loaded-files" id="loadedFiles"></div>
    </div>
