      <div class="chart-panel">
        <div class="chart-title">📊 Gastos Variables por Mes</div>
        <div class="chart-container"><canvas id="chartVarMes"></canvas></div>
      </div>
      <div class="chart-panel">
        <div class="chart-title">🍩 Distribución Gastos Variables</div>
        <div class="chart-container"><canvas id="chartVarPie"></canvas></div>
      </div>
    </div>
    <div class="table-wrap" id="varTableWrap" style="display:none">
      <div class="table-header">
        <h3>📋 Detalle Gastos Variables Cargados</h3>
        <input type="text" class="table-search" id="varSearch" placeholder="Buscar..." oninput="filterVarTable()">
      </div>
      <div class="table-overflow">
        <table id="varTable">
          <thead id="varTableHead"></thead>
          <tbody id="varTableBody"></tbody>
        </table>
      </div>
    </div>
