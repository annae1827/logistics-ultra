// ═══════════════════════════════════════════
// UPLOAD GASTOS VARIABLES (TC)
// ═══════════════════════════════════════════
function handleFileUpload(e) {
  const files = e.target.files;
  for (const file of files) { readUploadedFile(file); }
}

function handleDrop(e) {
  e.preventDefault();
  document.getElementById('uploadArea').classList.remove('drag-over');
  const files = e.dataTransfer.files;
  for (const file of files) { readUploadedFile(file); }
}

function handleDragOver(e) { e.preventDefault(); document.getElementById('uploadArea').classList.add('drag-over'); }
function handleDragLeave(e) { document.getElementById('uploadArea').classList.remove('drag-over'); }

function readUploadedFile(file) {
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      let data;
      if (file.name.endsWith('.csv')) {
        const text = e.target.result;
        const wb = XLSX.read(text, { type: 'string' });
        data = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
      } else {
        const ab = e.target.result;
        const wb = XLSX.read(ab, { type: 'array' });
        data = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
      }
      
      loadedFileNames.push(file.name);
      varData = varData.concat(data);
      renderLoadedFiles();
      renderVarDashboard();
    } catch(err) {
      alert('Error al leer archivo: ' + err.message);
    }
  };
  if (file.name.endsWith('.csv')) reader.readAsText(file);
  else reader.readAsArrayBuffer(file);
}

function renderLoadedFiles() {
  document.getElementById('loadedFiles').innerHTML = loadedFileNames.map((f, i) => `
    <div class="file-tag">📄 ${f} <span class="remove" onclick="removeFile(${i}); event.stopPropagation();">✕</span></div>
  `).join('');
}

function removeFile(i) {
  loadedFileNames.splice(i, 1);
  varData = []; // simplificado: recargar todos
  renderLoadedFiles();
  renderVarDashboard();
}

function renderVarDashboard() {
  if (varData.length === 0) {
    document.getElementById('kpiVarRow').innerHTML = '';
    document.getElementById('varTableWrap').style.display = 'none';
    if (charts.varMes) { charts.varMes.destroy(); charts.varMes = null; }
    if (charts.varPie) { charts.varPie.destroy(); charts.varPie = null; }
    return;
  }

  // Find amount column
  const keys = Object.keys(varData[0]);
  const amtKey = keys.find(k => /monto|importe|cargo|amount|total/i.test(k)) || keys.find(k => typeof varData[0][k] === 'number');
  const descKey = keys.find(k => /desc|concepto|comercio|detalle/i.test(k)) || keys[1];
  const dateKey = keys.find(k => /fecha|date/i.test(k)) || keys[0];

  const total = varData.reduce((s, d) => s + (parseNumber(d[amtKey]) || 0), 0);
  const avg = total / varData.length;

  document.getElementById('kpiVarRow').innerHTML = `
    <div class="kpi-card">
      <div class="kpi-label">Total Gastos Variables</div>
      <div class="kpi-value">${fmtK(total)}</div>
      <div class="kpi-sub">${varData.length} registros cargados</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Promedio por Registro</div>
      <div class="kpi-value">${fmt(avg)}</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Archivos Cargados</div>
      <div class="kpi-value">${loadedFileNames.length}</div>
    </div>
  `;

  // Var by month chart
  const byMonth = {};
  varData.forEach(d => {
    const dt = new Date(d[dateKey]);
    const key = !isNaN(dt) ? `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}` : 'Sin fecha';
    byMonth[key] = (byMonth[key] || 0) + (parseNumber(d[amtKey]) || 0);
  });
  const mKeys = Object.keys(byMonth).sort();

  if (charts.varMes) charts.varMes.destroy();
  charts.varMes = new Chart(document.getElementById('chartVarMes'), {
    type: 'bar',
    data: {
      labels: mKeys,
      datasets: [{ data: mKeys.map(k => byMonth[k]), backgroundColor: '#f59e0b', borderRadius: 6 }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false }, datalabels: { display: false } },
      scales: { y: { ticks: { callback: v => fmtK(v) } }, x: { grid: { display: false } } }
    },
    plugins: [ChartDataLabels]
  });

  // Var pie by description (top 8)
  const byConcept = {};
  varData.forEach(d => {
    const c = (d[descKey] || 'Otros').toString().substring(0, 30);
    byConcept[c] = (byConcept[c] || 0) + (parseNumber(d[amtKey]) || 0);
  });
  const topConcepts = Object.entries(byConcept).sort((a, b) => b[1] - a[1]).slice(0, 8);

  if (charts.varPie) charts.varPie.destroy();
  charts.varPie = new Chart(document.getElementById('chartVarPie'), {
    type: 'doughnut',
    data: {
      labels: topConcepts.map(c => c[0]),
      datasets: [{ data: topConcepts.map(c => c[1]), backgroundColor: COLORS.slice(0, 8) }]
    },
    options: {
      responsive: true,
      plugins: { legend: { position: 'right', labels: { font: { size: 10 } } }, datalabels: { display: false } }
    },
    plugins: [ChartDataLabels]
  });

  // Table
  document.getElementById('varTableWrap').style.display = 'block';
  const thead = document.getElementById('varTableHead');
  const displayKeys = keys.slice(0, 8);
  thead.innerHTML = '<tr>' + displayKeys.map(k => `<th>${k}</th>`).join('') + '</tr>';

  const tbody = document.getElementById('varTableBody');
  tbody.innerHTML = varData.slice(0, 300).map(d =>
    '<tr>' + displayKeys.map(k => `<td>${d[k] != null ? d[k] : ''}</td>`).join('') + '</tr>'
  ).join('');
}

function filterVarTable() {
  const q = document.getElementById('varSearch').value.toLowerCase();
  document.querySelectorAll('#varTableBody tr').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

// ═══════════════════════════════════════════
// EXPORTAR CSV
// ═══════════════════════════════════════════
function exportarCSV() {
  const headers = ['Fecha','Tipo de Gasto','Descripción','Categoría','Clasificación','Monto','Año'];
  const rows = filteredData.map(d => [d.fecha, d.tipo, d.desc, d.cat, d.clasif, d.monto, d.año]);
  let csv = headers.join(',') + '\n';
  rows.forEach(r => { csv += r.map(v => `"${v}"`).join(',') + '\n'; });
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'gastos_filtrados.csv';
  a.click();
}

