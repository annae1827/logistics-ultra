</div>

<!-- ═══════════ LOADING OVERLAY ═══════════ -->
<div class="loading" id="loadingOverlay">
  <div class="spinner"></div>
  <div class="loading-text">Cargando datos de gastos desde Google Sheets...</div>
</div>

<script>
// ═══════════════════════════════════════════
// CONFIGURACIÓN
// ═══════════════════════════════════════════
const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQUAaE4yC5wN6MxTnoCqzBZIkTDwjqpcmnu7Si4duNdjPCbkd6jaAEvZmJrLkaLIJ17mgAzpW5VwJsy/pub?gid=269206902&single=true&output=csv';

let allData = [];
let filteredData = [];
let varData = [];
let loadedFileNames = [];
let charts = {};
let sortDir = 1;

const COLORS = [
  '#0d9488','#f59e0b','#3b82f6','#ef4444','#8b5cf6',
  '#ec4899','#06b6d4','#84cc16','#f97316','#6366f1',
  '#14b8a6','#e11d48'
];

const MESES = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];

// ═══════════════════════════════════════════
// CARGA DE DATOS
// ═══════════════════════════════════════════
async function loadData() {
  try {
    const resp = await fetch(CSV_URL);
    if (!resp.ok) throw new Error('Error al cargar CSV');
    const text = await resp.text();
    allData = parseCSV(text);
    initDashboard();
  } catch(e) {
    console.error('Error cargando datos:', e);
    document.getElementById('loadingOverlay').innerHTML = `
      <div style="text-align:center;color:var(--gray-600);">
        <div style="font-size:2rem;margin-bottom:1rem;">⚠️</div>
        <div style="font-weight:700;margin-bottom:.5rem;">Error al cargar datos</div>
        <div style="font-size:.85rem;">CORS puede bloquear la carga desde localhost.<br>
        Sube este archivo a GitHub Pages para que funcione correctamente.<br><br>
        <strong>Error:</strong> ${e.message}</div>
      </div>`;
  }
}

function parseCSV(text) {
  const rows = [];
  const lines = text.split('\n');
  // Find header
  let headerIdx = 0;
  for (let i = 0; i < Math.min(5, lines.length); i++) {
    if (lines[i].includes('Fecha') && lines[i].includes('Monto')) {
      headerIdx = i;
      break;
    }
  }
  const headers = parseCSVLine(lines[headerIdx]);
  
  const colMap = {};
  headers.forEach((h, i) => {
    const clean = h.trim().toLowerCase();
    if (clean === 'fecha' && !colMap.fecha) colMap.fecha = i;
    if (clean === 'mes') colMap.mes = i;
    if (clean === 'tipo de gasto') colMap.tipo = i;
    if (clean.includes('descripci')) colMap.desc = i;
    if (clean === 'monto') colMap.monto = i;
    if (clean.includes('categor')) colMap.cat = i;
    if (clean.includes('clasificaci')) colMap.clasif = i;
    if (clean === 'año' || clean === 'ano') colMap.año = i;
    if (clean === 'tipo' && !colMap.tipoVar) colMap.tipoVar = i;
    if (clean === 'unidad') colMap.unidad = i;
    if (clean === 'operador') colMap.operador = i;
    if (clean === 'pagado por') colMap.pagadoPor = i;
  });

  for (let i = headerIdx + 1; i < lines.length; i++) {
    const line = lines[i].trim();
    if (!line) continue;
    const cols = parseCSVLine(line);
    
    const monto = parseNumber(cols[colMap.monto]);
    if (!monto && monto !== 0) continue;
    
    let fecha = cols[colMap.fecha] || '';
    let año = cols[colMap.año] || '';
    if (!año && fecha) {
      const d = new Date(fecha);
      if (!isNaN(d)) año = d.getFullYear();
    }
    
    rows.push({
      fecha: fecha,
      mes: cols[colMap.mes] || '',
      tipo: cols[colMap.tipo] || '',
      desc: cols[colMap.desc] || '',
      monto: monto,
      cat: cols[colMap.cat] || 'Sin Clasificar',
      clasif: cols[colMap.clasif] || 'Sin Clasificar',
      año: parseInt(año) || 0,
      unidad: cols[colMap.unidad] || '',
      operador: cols[colMap.operador] || '',
      pagadoPor: cols[colMap.pagadoPor] || '',
      tipoVar: cols[colMap.tipoVar] || ''
    });
  }
  return rows;
}

function parseCSVLine(line) {
  const result = [];
  let current = '';
  let inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') {
      if (inQuotes && line[i+1] === '"') { current += '"'; i++; }
      else inQuotes = !inQuotes;
    } else if (c === ',' && !inQuotes) {
      result.push(current.trim());
      current = '';
    } else {
      current += c;
    }
  }
  result.push(current.trim());
  return result;
}

function parseNumber(val) {
  if (val === null || val === undefined || val === '') return null;
  const cleaned = String(val).replace(/[$,\s]/g, '').replace(/"/g, '');
  const n = parseFloat(cleaned);
  return isNaN(n) ? null : n;
}

function fmt(n) {
  if (n === null || n === undefined) return '$0';
  return '$' + n.toLocaleString('es-MX', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function fmtK(n) {
  if (Math.abs(n) >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
  if (Math.abs(n) >= 1e3) return '$' + (n/1e3).toFixed(0) + 'K';
  return fmt(n);
}

// ═══════════════════════════════════════════
// INIT DASHBOARD
// ═══════════════════════════════════════════
function initDashboard() {
  document.getElementById('loadingOverlay').style.display = 'none';
  populateFilters();
  filteredData = [...allData];
  renderAll();
}

function populateFilters() {
  const years = [...new Set(allData.map(d => d.año).filter(y => y > 0))].sort();
  const cats = [...new Set(allData.map(d => d.cat).filter(Boolean))].sort();
  const clasifs = [...new Set(allData.map(d => d.clasif).filter(Boolean))].sort();

  const fy = document.getElementById('filterYear');
  years.forEach(y => { const o = document.createElement('option'); o.value = y; o.textContent = y; fy.appendChild(o); });

  const fc = document.getElementById('filterCat');
  cats.forEach(c => { const o = document.createElement('option'); o.value = c; o.textContent = c; fc.appendChild(o); });

  const fl = document.getElementById('filterClasif');
  clasifs.forEach(c => { const o = document.createElement('option'); o.value = c; o.textContent = c; fl.appendChild(o); });
}

function applyFilters() {
  const y = document.getElementById('filterYear').value;
  const c = document.getElementById('filterCat').value;
  const cl = document.getElementById('filterClasif').value;

  filteredData = allData.filter(d => {
    if (y !== 'all' && d.año !== parseInt(y)) return false;
    if (c !== 'all' && d.cat !== c) return false;
    if (cl !== 'all' && d.clasif !== cl) return false;
    return true;
  });
  renderAll();
}

