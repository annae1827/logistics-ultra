<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard de Gastos — Logistics Ultra</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
:root {
  --teal-900: #134e4a;
  --teal-800: #115e59;
  --teal-700: #0f766e;
  --teal-600: #0d9488;
  --teal-500: #14b8a6;
  --teal-400: #2dd4bf;
  --teal-100: #ccfbf1;
  --teal-50: #f0fdfa;
  --gray-900: #111827;
  --gray-700: #374151;
  --gray-600: #4b5563;
  --gray-500: #6b7280;
  --gray-400: #9ca3af;
  --gray-200: #e5e7eb;
  --gray-100: #f3f4f6;
  --gray-50: #f9fafb;
  --red-500: #ef4444;
  --amber-500: #f59e0b;
  --green-500: #22c55e;
  --blue-500: #3b82f6;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  background: var(--gray-100);
  color: var(--gray-900);
  min-height: 100vh;
}

/* ── HEADER ── */
.header {
  background: linear-gradient(135deg, var(--teal-900), var(--teal-700));
  color: #fff;
  padding: 1.25rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
}
.header h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -.5px; }
.header .sub { font-size: .85rem; opacity: .75; margin-top: 2px; }
.header-right { display: flex; gap: .75rem; align-items: center; }
.btn {
  padding: .5rem 1rem;
  border: none;
  border-radius: 6px;
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .2s;
}
.btn-outline { background: transparent; border: 1.5px solid rgba(255,255,255,.5); color: #fff; }
.btn-outline:hover { background: rgba(255,255,255,.15); border-color: #fff; }
.btn-solid { background: var(--teal-400); color: var(--teal-900); }
.btn-solid:hover { background: var(--teal-500); }

/* ── TABS ── */
.tabs {
  display: flex;
  gap: 0;
  background: var(--teal-800);
  padding: 0 2rem;
  overflow-x: auto;
}
.tab {
  padding: .75rem 1.25rem;
  color: rgba(255,255,255,.6);
  font-size: .82rem;
  font-weight: 600;
  cursor: pointer;
  border-bottom: 3px solid transparent;
  white-space: nowrap;
  transition: all .2s;
}
.tab:hover { color: #fff; background: rgba(255,255,255,.05); }
.tab.active { color: #fff; border-bottom-color: var(--teal-400); }

/* ── FILTERS ── */
.filters {
  display: flex;
  gap: .75rem;
  padding: 1rem 2rem;
  background: #fff;
  border-bottom: 1px solid var(--gray-200);
  flex-wrap: wrap;
  align-items: center;
}
.filter-group { display: flex; align-items: center; gap: .4rem; }
.filter-group label { font-size: .75rem; color: var(--gray-500); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
.filter-group select {
  padding: .4rem .75rem;
  border: 1.5px solid var(--gray-200);
  border-radius: 6px;
  font-size: .82rem;
  background: #fff;
  color: var(--gray-700);
  cursor: pointer;
}
.filter-group select:focus { outline: none; border-color: var(--teal-500); }

/* ── MAIN CONTENT ── */
.main { padding: 1.5rem 2rem; max-width: 1440px; margin: 0 auto; }

/* ── KPI CARDS ── */
.kpi-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.kpi-card {
  background: #fff;
  border-radius: 10px;
  padding: 1.25rem;
  border: 1px solid var(--gray-200);
  position: relative;
  overflow: hidden;
}
.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--teal-500);
}
.kpi-card.danger::before { background: var(--red-500); }
.kpi-card.warning::before { background: var(--amber-500); }
.kpi-label { font-size: .72rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: .5px; font-weight: 600; }
.kpi-value { font-size: 1.6rem; font-weight: 800; color: var(--gray-900); margin-top: .25rem; }
.kpi-sub { font-size: .75rem; color: var(--gray-500); margin-top: .25rem; }
.kpi-change { font-size: .75rem; font-weight: 600; margin-top: .25rem; }
.kpi-change.up { color: var(--red-500); }
.kpi-change.down { color: var(--green-500); }

/* ── CHART PANELS ── */
.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.chart-panel {
  background: #fff;
  border-radius: 10px;
  padding: 1.25rem;
  border: 1px solid var(--gray-200);
}
.chart-panel.full { grid-column: 1 / -1; }
.chart-title {
  font-size: .85rem;
  font-weight: 700;
  color: var(--gray-700);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: .5rem;
}
.chart-title .icon { font-size: 1rem; }
.chart-container { position: relative; width: 100%; }
.chart-container canvas { width: 100% !important; }

/* ── TABLE ── */
.table-wrap {
  background: #fff;
  border-radius: 10px;
  border: 1px solid var(--gray-200);
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.table-header {
  padding: 1rem 1.25rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--gray-200);
}
.table-header h3 { font-size: .85rem; font-weight: 700; color: var(--gray-700); }
.table-search {
  padding: .4rem .75rem;
  border: 1.5px solid var(--gray-200);
  border-radius: 6px;
  font-size: .8rem;
  width: 220px;
}
.table-search:focus { outline: none; border-color: var(--teal-500); }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: .78rem;
}
thead th {
  background: var(--gray-50);
  padding: .65rem .75rem;
  text-align: left;
  font-weight: 700;
  color: var(--gray-600);
  text-transform: uppercase;
  font-size: .7rem;
  letter-spacing: .5px;
  border-bottom: 2px solid var(--gray-200);
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
thead th:hover { color: var(--teal-700); }
tbody td {
  padding: .6rem .75rem;
  border-bottom: 1px solid var(--gray-100);
  color: var(--gray-700);
}
tbody tr:hover { background: var(--teal-50); }
.text-right { text-align: right; }
.table-overflow { overflow-x: auto; max-height: 450px; overflow-y: auto; }

/* ── UPLOAD AREA ── */
.upload-section {
  background: #fff;
  border-radius: 10px;
  border: 2px dashed var(--gray-300);
  padding: 2rem;
  text-align: center;
  margin-bottom: 1.5rem;
  transition: all .2s;
  cursor: pointer;
}
.upload-section:hover, .upload-section.drag-over {
  border-color: var(--teal-500);
  background: var(--teal-50);
}
.upload-icon { font-size: 2.5rem; margin-bottom: .75rem; }
.upload-title { font-size: .95rem; font-weight: 700; color: var(--gray-700); margin-bottom: .25rem; }
.upload-sub { font-size: .8rem; color: var(--gray-500); }
.upload-file-input { display: none; }

/* ── LOADED FILES ── */
.loaded-files {
  display: flex; gap: .5rem; flex-wrap: wrap; margin-top: 1rem;
}
.file-tag {
  background: var(--teal-100);
  color: var(--teal-800);
  padding: .3rem .75rem;
  border-radius: 20px;
  font-size: .75rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: .4rem;
}
.file-tag .remove {
  cursor: pointer;
  font-weight: 800;
  opacity: .6;
}
.file-tag .remove:hover { opacity: 1; }

/* ── TAB CONTENT ── */
.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── LOADING ── */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rem;
  flex-direction: column;
  gap: 1rem;
}
.spinner {
  width: 40px; height: 40px;
  border: 4px solid var(--gray-200);
  border-top-color: var(--teal-500);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: .85rem; color: var(--gray-500); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .header { padding: 1rem; }
  .tabs { padding: 0 1rem; }
  .filters { padding: .75rem 1rem; }
  .main { padding: 1rem; }
  .charts-grid { grid-template-columns: 1fr; }
  .kpi-row { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<div class="header">
  <div>
    <h1>📊 Dashboard de Gastos</h1>
    <div class="sub">Logistics Ultra — Control Financiero</div>
  </div>
  <div class="header-right">
    <button class="btn btn-outline" onclick="exportarCSV()">⬇ Exportar CSV</button>
    <button class="btn btn-solid" onclick="document.getElementById('fileInput').click()">📁 Cargar Gastos Variables</button>
    <input type="file" id="fileInput" class="upload-file-input" accept=".xlsx,.xls,.csv" multiple onchange="handleFileUpload(event)">
  </div>
</div>

<div class="tabs">
  <div class="tab active" onclick="switchTab('resumen')">Resumen General</div>
  <div class="tab" onclick="switchTab('anual')">Análisis Anual</div>
  <div class="tab" onclick="switchTab('categorias')">Por Categoría</div>
  <div class="tab" onclick="switchTab('mensual')">Tendencia Mensual</div>
  <div class="tab" onclick="switchTab('detalle')">Detalle & Tabla</div>
  <div class="tab" onclick="switchTab('variables')">Gastos Variables (TC)</div>
</div>

<div class="filters" id="globalFilters">
  <div class="filter-group">
    <label>Año</label>
    <select id="filterYear" onchange="applyFilters()">
      <option value="all">Todos</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Categoría</label>
    <select id="filterCat" onchange="applyFilters()">
      <option value="all">Todas</option>
    </select>
  </div>
  <div class="filter-group">
    <label>Clasificación</label>
    <select id="filterClasif" onchange="applyFilters()">
      <option value="all">Todas</option>
    </select>
  </div>
</div>

<div class="main">

  <!-- ═══ TAB: RESUMEN ═══ -->
  <div class="tab-content active" id="tab-resumen">
    <div class="kpi-row" id="kpiRow"></div>
    <div class="charts-grid">
      <div class="chart-panel full">
        <div class="chart-title">📈 Gasto Total por Año</div>
        <div class="chart-container"><canvas id="chartAnual"></canvas></div>
      </div>
      <div class="chart-panel">
        <div class="chart-title">🍩 Distribución por Categoría</div>
        <div class="chart-container"><canvas id="chartCatPie"></canvas></div>
      </div>
      <div class="chart-panel">
        <div class="chart-title">📊 Top 10 Clasificaciones</div>
        <div class="chart-container"><canvas id="chartTopClasif"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB: ANUAL ═══ -->
  <div class="tab-content" id="tab-anual">
    <div class="charts-grid">
      <div class="chart-panel full">
        <div class="chart-title">📊 Comparativo Anual por Categoría</div>
        <div class="chart-container"><canvas id="chartAnualCat"></canvas></div>
      </div>
      <div class="chart-panel full">
        <div class="chart-title">📈 Gasto Acumulado por Año</div>
        <div class="chart-container"><canvas id="chartAnualAcum"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB: CATEGORÍAS ═══ -->
  <div class="tab-content" id="tab-categorias">
    <div class="charts-grid">
      <div class="chart-panel full">
        <div class="chart-title">📊 Desglose por Categoría</div>
        <div class="chart-container"><canvas id="chartCatBar"></canvas></div>
      </div>
      <div class="chart-panel full">
        <div class="chart-title">📋 Tabla Resumen por Categoría</div>
        <div class="table-overflow" id="tableCatResumen"></div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB: MENSUAL ═══ -->
  <div class="tab-content" id="tab-mensual">
    <div class="charts-grid">
      <div class="chart-panel full">
        <div class="chart-title">📈 Tendencia Mensual de Gastos</div>
        <div class="chart-container"><canvas id="chartMensual"></canvas></div>
      </div>
      <div class="chart-panel full">
        <div class="chart-title">🔥 Heatmap Mensual por Año</div>
        <div class="chart-container"><canvas id="chartHeatmap"></canvas></div>
      </div>
    </div>
  </div>

  <!-- ═══ TAB: DETALLE ═══ -->
  <div class="tab-content" id="tab-detalle">
    <div class="table-wrap">
      <div class="table-header">
        <h3>📋 Detalle de Gastos (últimos 500 registros)</h3>
        <input type="text" class="table-search" id="tableSearch" placeholder="Buscar..." oninput="filterTable()">
      </div>
      <div class="table-overflow">
        <table id="detalleTable">
          <thead>
            <tr>
              <th onclick="sortTable(0)">Fecha ↕</th>
              <th onclick="sortTable(1)">Tipo de Gasto ↕</th>
              <th onclick="sortTable(2)">Descripción ↕</th>
              <th onclick="sortTable(3)">Categoría ↕</th>
              <th onclick="sortTable(4)">Clasificación ↕</th>
              <th onclick="sortTable(5)" class="text-right">Monto ↕</th>
